# Copy this file to terraform.tfvars and fill in your values.
# Do NOT commit terraform.tfvars – it is git-ignored.

cloudflare_api_token  = ""
cloudflare_account_id = ""
r2_bucket_name        = "primalprinting-media"
r2_location           = "APAC"

# Order system buckets
r2_staging_bucket_name   = "primalprinting-staging"
r2_permanent_bucket_name = "primalprinting-orders"
r2_staging_expiry_days   = 7

# Headless asset hosting
# Set r2_assets_custom_domain + r2_assets_zone_id to attach a custom domain
# (recommended for production). Leave both empty to use the R2.dev subdomain.
r2_assets_bucket_name     = "primalprinting-assets"
r2_assets_custom_domain   = ""
r2_assets_zone_id         = ""
r2_assets_max_age_seconds = 31536000
