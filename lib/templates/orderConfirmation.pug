include _mixins

doctype html
html
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    include _styles
  body
    .container
      .header
        h1 Order Confirmed ✓
        p Order ##{orderNumber}

      .content
        p Hi #{customerName},

        p Your order has been confirmed and payment received. Here's your order summary:

        +fileList(files)

        +pricingTable(subtotal, tax, total)

        .section
          .pickup-box
            h3 📍 Pickup Details
            p
              strong Date:&nbsp;
              | #{pickupDate}
            p
              strong Time:&nbsp;
              | #{pickupTime}
            if pickupLabel
              p
                strong Slot:&nbsp;
                | #{pickupLabel}

        p If you have any questions, please contact us:
        +contactAndFooter(contactEmail, contactPhone)

      .footer
        p Primal Printing — Thank you for your order!
